# Veridex Environment Configuration

# Phase 2 & 4: Stylometry, Bias, and Sentiment ML
VERIDEX_ENABLE_ML="1"

# Phase 3: Audio Transcription
VERIDEX_ENABLE_AUDIO_TRANSCRIPTION="1"
VERIDEX_WHISPER_MODEL="base"

# Phase 2: Live Fact-Checking (Requires Google API Key)
VERIDEX_ENABLE_LIVE_FACTCHECK="1"
GOOGLE_FACTCHECK_API_KEY="..."

# Phase 4 & 5: Security & Infrastructure
VERIDEX_API_KEY="veridex_admin_2026"
VERIDEX_ENABLE_LEDGER="1"

# Database (Supabase)
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
